# Copie este arquivo para ".env" (git-ignorado) e preencha com valores reais locais.

ENVIRONMENT=development

# Banco de staging/controle da plataforma (PostgreSQL nativo local).
DATABASE_URL=postgresql+asyncpg://migracao_app:CHANGE_ME@localhost:5432/migracao_platform

# Reservado para a camada de integração de destino (Oracle) — configurado a partir da Fase 3+.
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
